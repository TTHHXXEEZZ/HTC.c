datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String?
  photoUrl  String?
  role      String   @default("student")
  createdAt DateTime @default(now())
}

model Workplace {
  id            String   @id @default(uuid())
  name          String
  category      String
  description   String
  address       String
  website       String?
  phone         String?
  department    String
  lat           Float
  lng           Float
  coverImage    String
  views         Int      @default(0)
  reviews       Review[]
  createdAt     DateTime @default(now())
}

model Review {
  id           String    @id @default(uuid())
  workplaceId  String
  workplace    Workplace @relation(fields: [workplaceId], references: [id], onDelete: Cascade)
  reviewerName String
  reviewerDept String
  rating       Int
  content      String
  createdAt    DateTime  @default(now())
}

model SiteView {
  id        Int      @id @default(1)
  count     Int      @default(0)
  updatedAt DateTime @updatedAt
}
